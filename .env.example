# Example environment variables for FollowFlow
# Copy this file to `.env` and replace values with your credentials.

# Server
PORT=3000
NODE_ENV=development

# AI Providers
# Fallback order: OpenAI → Anthropic → Gemini → Ollama (when no keys are set)
#
# Ollama — local or remote inference, no API key required.
# For Vercel deployments: Ollama cannot run on Vercel's servers.
# You must expose your local Ollama instance via a public URL
# (e.g. ngrok: `ngrok http 11434`) and set OLLAMA_BASE_URL to that URL.
# Then add OLLAMA_BASE_URL to your Vercel project's Environment Variables.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# OAuth / Integrations (placeholders for demo)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Optional: app-specific settings
APP_BASE_URL=http://localhost:5173

# Debug
LOG_LEVEL=info

# Example environment variables for FollowFlow
# Copy this file to `.env` and replace values with your credentials.

# Server
PORT=3000
NODE_ENV=development

# AI Providers
# Fallback order: OpenAI → Anthropic → Gemini → Groq → Ollama
#
# FREE OPTIONS (no credit card required):
#
# 1. Groq — free tier, Llama 3.3 70B, very fast. Get a key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
#
# 2. Gemini — free tier (15 RPM, 1,500 req/day). Get a key at https://aistudio.google.com
GEMINI_API_KEY=
#
# PAID OPTIONS:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
#
# Ollama — local or remote inference, no API key required.
# For Vercel deployments: Ollama cannot run on Vercel's servers.
# You must expose your local Ollama instance via a public URL
# (e.g. ngrok: `ngrok http 11434`) and set OLLAMA_BASE_URL to that URL.
# Then add OLLAMA_BASE_URL to your Vercel project's Environment Variables.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

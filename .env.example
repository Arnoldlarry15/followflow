# Example environment variables for FollowFlow
# Copy this file to `.env` and replace values with your credentials.

# Server
PORT=3000
NODE_ENV=development

# AI Providers (leave empty if using local Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# OAuth / Integrations (placeholders for demo)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Optional: app-specific settings
APP_BASE_URL=http://localhost:3000

# Debug
LOG_LEVEL=info

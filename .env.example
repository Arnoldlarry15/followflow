# Example environment variables for FollowFlow
# Copy this file to `.env` and replace values with your credentials.

# Server
PORT=3000
NODE_ENV=development

# AI Providers — Groq is the preferred provider for best performance
# To use Groq, get an API key from https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=30000

# Optional: Ollama (local inference, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Optional: Other cloud providers (will auto-fallback if Groq key is missing)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# OAuth / Integrations (placeholders for demo)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Optional: app-specific settings
APP_BASE_URL=http://localhost:3000

# Debug
LOG_LEVEL=info
